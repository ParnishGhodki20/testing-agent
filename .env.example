# ─────────────────────────────────────────────
# Ollama — single generator model
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Generator model — used for ALL generation (scenarios, TCs, general QA).
# No separate verifier model — verification is done by deterministic Python evals.
#
# Recommended: qwen2.5:7b  (best quality/speed tradeoff for local use)
#   To install:  ollama pull qwen2.5:7b
#
# Alternative: qwen2.5:3b  (faster but more format drift, works on 4GB RAM)
#   To install:  ollama pull qwen2.5:3b
#
# For best results: qwen2.5:14b (needs ~10GB RAM)
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Embedding model — for document indexing
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2

# ─────────────────────────────────────────────
# Azure DevOps (required only for ADO push)
# ─────────────────────────────────────────────
ADO_PAT=
ADO_BASE_URL=https://dev.azure.com/your-org
ADO_PROJECT=
ADO_AREA_PATH=
ADO_ITERATION_PATH=
ADO_FEATURE_ID=
ADO_ASSIGNED_TO=
ADO_TAG=GeneratedByCopilot

# ─────────────────────────────────────────────
# RAG / Retrieval tuning
# ─────────────────────────────────────────────
# Chunk size in characters — 1500 keeps full requirement paragraphs intact.
# DO NOT reduce below 1000 — fragmenting requirements causes poor generation.
TEXT_SPLITTER_CHUNK_SIZE=1500

# Overlap between consecutive chunks (~13% of chunk size).
# Preserves sentence boundaries across chunk edges.
TEXT_SPLITTER_CHUNK_OVERLAP=200

# Number of chunks returned per retrieval query (6 × 1500 = 9000 chars of context)
RETRIEVER_K=6

# MMR candidate pool size (must be >= RETRIEVER_K)
RETRIEVER_FETCH_K=20

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
OCR_TIMEOUT=5
HEADLESS=true
DEBUG=false

# ─────────────────────────────────────────────
# Test case generation performance
# ─────────────────────────────────────────────
# Scenarios per LLM batch call (3 = sweet spot for 3b–7b models)
TC_BATCH_SIZE=3

# Hard timeout per batch in seconds (prevents stuck generation)
TC_TIMEOUT_SECS=120

# Max tokens the TC generator may produce per batch.
# At ~25 tok/s (7b), 2000 tokens ≈ 80s — enough for 3-5 TCs per scenario.
TC_NUM_PREDICT=2000

# ─────────────────────────────────────────────
# Fast mode (for demos / quick iteration)
# ─────────────────────────────────────────────
# When true:
#   - eval retries are skipped (Python checks still run but don't trigger retry)
#   - uses FAST_TC_NUM_PREDICT tokens (shorter, faster output)
FAST_MODE=false
FAST_TC_NUM_PREDICT=1200
