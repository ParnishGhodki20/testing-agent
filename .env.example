# ─────────────────────────────────────────────
# Ollama
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Generator model — used for scenario / TC / general QA generation
# Recommended: qwen2.5:7b  (better quality than 3b, still fast locally)
# Alternative: llama3.1:8b, mistral:7b
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Verifier model — second-pass validation
# Can be same as CHAT_MODEL or a larger model for stricter checking
# Recommended: qwen2.5:7b or qwen2.5:14b
OLLAMA_VERIFY_MODEL=qwen2.5:7b

# Embedding model — for document indexing
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2

# ─────────────────────────────────────────────
# Azure DevOps (required only for ADO push)
# ─────────────────────────────────────────────
ADO_PAT=
ADO_BASE_URL=https://dev.azure.com/your-org
ADO_PROJECT=
ADO_AREA_PATH=
ADO_ITERATION_PATH=
ADO_FEATURE_ID=
ADO_ASSIGNED_TO=
ADO_TAG=GeneratedByCopilot

# ─────────────────────────────────────────────
# RAG / Retrieval tuning
# ─────────────────────────────────────────────
# Chunk size in characters (larger = more context per chunk)
TEXT_SPLITTER_CHUNK_SIZE=1500
# Overlap between consecutive chunks
TEXT_SPLITTER_CHUNK_OVERLAP=150
# Number of chunks returned per retrieval query
RETRIEVER_K=8
# MMR candidate pool size (must be >= RETRIEVER_K)
RETRIEVER_FETCH_K=20

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
OCR_TIMEOUT=5
HEADLESS=true
DEBUG=false

# ─────────────────────────────────────────────
# Test case generation performance
# ─────────────────────────────────────────────
# Scenarios per LLM batch call (default 3, sweet spot for 3b–7b models)
# Lower = more calls but faster per call. Raise to 5 only if using 7b+.
TC_BATCH_SIZE=3

# Hard timeout per batch in seconds (prevents stuck generation)
# If a batch exceeds this, it is skipped and the next batch continues.
TC_TIMEOUT_SECS=90

# Max tokens the TC generator may produce per batch
# 1500 is enough for 3 scenarios × ~3 TCs each. Raise if TCs are truncated.
TC_NUM_PREDICT=1500

# Max tokens the verifier may output (only a short verdict needed)
VERIFY_NUM_PREDICT=1000

